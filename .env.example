# ─── AWS Configuration ────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=000000000000
AWS_ENDPOINT_URL=http://localhost:4566

# ─── DynamoDB ─────────────────────────────────────────────────────────────────
DYNAMODB_TABLE_NAME=vaultstream-metadata

# ─── S3 ───────────────────────────────────────────────────────────────────────
S3_FILES_BUCKET=vaultstream-files-local
S3_THUMBNAILS_BUCKET=vaultstream-thumbnails-local
S3_FRONTEND_BUCKET=vaultstream-frontend-local

# ─── RDS PostgreSQL ───────────────────────────────────────────────────────────
RDS_HOST=localhost
RDS_PORT=5432
RDS_DATABASE=vaultstream
RDS_USERNAME=vaultstream
RDS_PASSWORD=localdev123
RDS_READ_REPLICA_HOST=localhost
RDS_SSL=false

# ─── ElastiCache Redis ────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=localdev123
REDIS_TLS_ENABLED=false

# ─── KMS ──────────────────────────────────────────────────────────────────────
KMS_KEY_ID=alias/vaultstream-master-key

# ─── Cognito ──────────────────────────────────────────────────────────────────
COGNITO_USER_POOL_ID=us-east-1_LOCAL
COGNITO_APP_CLIENT_ID=local-client-id
COGNITO_DOMAIN=http://localhost:9229

# ─── CloudFront ───────────────────────────────────────────────────────────────
CLOUDFRONT_DOMAIN=localhost
CLOUDFRONT_KEY_PAIR_ID=LOCAL_KEY_PAIR
CLOUDFRONT_PRIVATE_KEY_SECRET=vaultstream/cloudfront-private-key

# ─── SQS ──────────────────────────────────────────────────────────────────────
SQS_THUMBNAIL_QUEUE_URL=http://localhost:4566/000000000000/vaultstream-thumbnail-queue
SQS_VIRUS_SCAN_QUEUE_URL=http://localhost:4566/000000000000/vaultstream-virus-scan-queue

# ─── SNS ──────────────────────────────────────────────────────────────────────
SNS_NOTIFICATIONS_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:vaultstream-notifications

# ─── Application ──────────────────────────────────────────────────────────────
APP_DOMAIN=http://localhost:3000
API_URL=http://localhost:4000
API_PORT=4000
NODE_ENV=development
LOG_LEVEL=debug

# ─── Limits ───────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_BYTES=104857600
MAX_STORAGE_FREE_TIER=5368709120
MAX_STORAGE_PRO_TIER=107374182400
MAX_STORAGE_ENTERPRISE_TIER=1099511627776
PRESIGNED_URL_EXPIRY_SECONDS=300
DOWNLOAD_URL_EXPIRY_SECONDS=900
